rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funzioni helper per sicurezza
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isChef() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/chefdechantiers/$(request.auth.uid));
    }
    
    function isCollaborateur() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/collaborateurs/$(request.auth.uid));
    }
    
    function rateLimitCheck() {
      return request.time > resource.data.lastAction + duration.value(1, 's');
    }

    // Audit log - solo creazione e lettura admin
    match /audit_log/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false; // Log immutabili
    }

    // Utenti - accesso limitato
    match /admins/{userId} {
      allow read, write: if isAdmin() && request.auth.uid == userId;
      allow read: if isAdmin(); // Admin possono vedere altri admin
      allow delete: if false; // Mai cancellare admin
    }
    
    match /chefdechantiers/{userId} {
      allow read, write: if (isAdmin() || (isChef() && request.auth.uid == userId));
      allow delete: if isAdmin();
    }
    
    match /collaborateurs/{userId} {
      allow read, write: if (isAdmin() || (isCollaborateur() && request.auth.uid == userId));
      allow delete: if isAdmin();
    }

    // Dati aziendali - protezione elevata
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isChef();
      allow delete: if isAdmin() && rateLimitCheck();
    }
    
    match /chantiers/{chantierId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isChef();
      allow delete: if isAdmin() && rateLimitCheck();
    }
    
    match /devis/{devisId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isChef();
      allow delete: if isAdmin() && rateLimitCheck();
    }

    // Dati finanziari - massima protezione
    match /factures/{factureId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow delete: if false; // Mai cancellare fatture
    }
    
    match /reportsMensuels/{reportId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow delete: if false; // Mai cancellare report
    }

    // Métrages - accesso controllato
    match /metrages/{metrageId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isChef();
      allow delete: if isAdmin() && rateLimitCheck();
    }

    // Ore lavoro - accesso per ruolo
    match /heures/{heureId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isChef() || 
                     (isCollaborateur() && request.auth.uid == resource.data.userId);
      allow delete: if isAdmin();
    }
    
    match /heuresChef/{heureId} {
      allow read: if isAdmin() || isChef();
      allow write: if isAdmin() || (isChef() && request.auth.uid == resource.data.chefId);
      allow delete: if isAdmin();
    }

    // Repertori - accesso base
    match /produits/{produitId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow delete: if isAdmin() && rateLimitCheck();
    }
    
    match /supplements/{supplementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow delete: if isAdmin() && rateLimitCheck();
    }
    
    match /familles/{familleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow delete: if isAdmin() && rateLimitCheck();
    }
    
    match /sousfamilles/{sousfamilleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow delete: if isAdmin() && rateLimitCheck();
    }
    
    match /paiements/{paiementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow delete: if isAdmin() && rateLimitCheck();
    }
    
    match /conditions/{conditionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow delete: if isAdmin() && rateLimitCheck();
    }
    
    match /techniciens/{technicienId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow delete: if isAdmin() && rateLimitCheck();
    }
    
    match /interimaires/{interimaireId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isChef();
      allow delete: if isAdmin() && rateLimitCheck();
    }
    
    match /regies/{regieId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow delete: if isAdmin() && rateLimitCheck();
    }

    // Fallback - nega tutto il resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}